{
  "database": {
    "host": "localhost",
    "dialect": "sqlite",
    "storage": "./igo.db"
  },
  "server": {
    "port": 5000,
    "adminProfil": "admin",
    "userApi": "http://localhost:8001",
    "plugins": ["logger", "sanitizer", "swagger"],
    "pluginsOptions": {
      "swagger": {
        "basePath": "/",
        "info": {
          "title": "Igo2 Authentification DEV",
          "description": "Igo2 Authentification Api Documentation",
          "version": "0.1.0"
        },
        "tags": [
          {
            "name": "users",
            "description": "Api users interface."
          }
        ],
        "documentationPath": "/docs",
        "jsonPath": "/docs/swagger.json",
        "lang": "en",
        "swaggerUIPath": "/swaggerui/"
      }
    },
    "routes": [
      "layer",
      "tool",
      "poi",
      "catalog",
      "context",
      "contextPermission",
      "layerContext",
      "toolContext"
    ],
    "localhost": {
      "hosts": [
        "spssogl97d.sso.msp.gouv.qc.ca",
        "beta.geomsp.qc",
        "testgeoegl.msp.gouv.qc.ca"
      ],
      "basePaths": ["/igo2/api/"]
    }
  }
}
